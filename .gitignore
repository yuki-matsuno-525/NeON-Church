# ==============================================================
# NeON-Church .gitignore
# ==============================================================

# ---------------------------------------------------------------
# 環境変数（絶対にコミットしないこと）
# ---------------------------------------------------------------
.env
.env.local
.env.*.local

# ---------------------------------------------------------------
# Python / Django
# ---------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.so
.venv/
venv/
ENV/

# pytest
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# mypy
.mypy_cache/

# ---------------------------------------------------------------
# Node.js / Next.js
# ---------------------------------------------------------------
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------
# Docker
# ---------------------------------------------------------------
# ローカルのボリュームデータ（DB データなど）
data/

# ---------------------------------------------------------------
# OS
# ---------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------
# IDE
# ---------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
