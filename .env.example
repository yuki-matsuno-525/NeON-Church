# ==============================================================
# NeON-Church 環境変数テンプレート
# このファイルをコピーして .env を作成し、各値を設定してください。
# .env は Git にコミットしないこと（.gitignore に追加済み）。
# ==============================================================

# ---------------------------------------------------------------
# Django
# ---------------------------------------------------------------
# 本番では必ず長いランダム文字列に変更すること。
# 生成例: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=your-secret-key-here

# 開発時は "True"、本番は必ず "False"（True のままだとデバッグページからスタックトレースが漏洩する）
DJANGO_DEBUG=True

# カンマ区切りで許可するホストを列挙（本番: api.neon-church.com）
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF を許可するオリジン（本番: https://neon-church.com）
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# CORS を許可するオリジン（本番: https://neon-church.com）
# Cookie 認証では CORS_ALLOW_CREDENTIALS=True と本オリジン列挙の両方が必要。
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Sentry DSN（エラー監視。未設定の場合は Sentry に送信しない）
SENTRY_DSN=

# ---------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------
POSTGRES_DB=neon_church
POSTGRES_USER=neon_user
POSTGRES_PASSWORD=neon_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------------------------------------------------------------
# OAuth（Google / GitHub）
# ---------------------------------------------------------------
# Google Cloud Console > API とサービス > 認証情報 で OAuth 2.0 クライアントを作成
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 本番: https://api.neon-church.com/api/auth/oauth/google/callback/
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback/

# GitHub > Settings > Developer settings > OAuth Apps で作成
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# 本番: https://api.neon-church.com/api/auth/oauth/github/callback/
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/oauth/github/callback/

# フロントエンドの URL（OAuth コールバック後のリダイレクト先）
# 本番: https://neon-church.com
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------
# バックエンド API のベース URL（フロントエンドからのリクエスト先）
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# サイトの公開 URL（OGP の metadataBase に使用）
# 本番: https://neon-church.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OAuth ボタンの表示制御（true で有効化）
NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_OAUTH_GITHUB_ENABLED=false

# Sentry DSN（フロントエンド用。未設定の場合は送信しない）
NEXT_PUBLIC_SENTRY_DSN=
